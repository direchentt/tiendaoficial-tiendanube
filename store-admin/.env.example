# PostgreSQL
# Railway plugin Postgres: DATABASE_URL se referencia desde el servicio.
#
# Supabase desde Railway: la conexion DIRECTA db.*.supabase.co:5432 suele fallar (P1001) por red IPv4/IPv6.
# Usa la URI del POOLER en Supabase: Settings -> Database -> Connection string -> "Session pooler"
# o "Transaction pooler" (host tipo aws-0-XX.pooler.supabase.com, NO db.XXX.supabase.co).
# Agrega si falta: ?sslmode=require
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require"

# Firma simple para rutas /api/admin/* (definir un secreto largo)
ADMIN_SECRET="cambiar-por-secreto-largo"

# Tienda (tras instalar app OAuth en la tienda)
TN_STORE_USER_ID=""
TN_ACCESS_TOKEN=""
# Obligatorio: "MiApp (https://...) o email"
TN_USER_AGENT="MiApp (contacto@tudominio.com)"

# Opcional: tiendas BR usan api.nuvemshop.com.br
# TN_API_HOST=nuvemshop

# URL publica del panel (para mostrar el link del webhook en /admin)
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

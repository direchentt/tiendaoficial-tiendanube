# ──────────────────────────────────────────────────
# store-admin — Variables de entorno locales
# Copiá este archivo a .env y completá los valores.
# En Railway estas variables se configuran en el
# panel del servicio (Variables tab).
# ──────────────────────────────────────────────────

# PostgreSQL — Supabase Session Pooler
# Formato correcto: Settings → Database → Connection string → Session pooler
# Host tipo: aws-0-XX.pooler.supabase.com  (NO db.XXX.supabase.co)
DATABASE_URL="postgresql://postgres.wqftgsnqwmvdbyytwoht:[TU_PASSWORD_SUPABASE]@aws-1-us-west-2.pooler.supabase.com:5432/postgres?pgbouncer=true&connection_limit=1"

# Secreto del panel admin (sin comillas en el valor si lo pegás en Railway)
ADMIN_SECRET="5639"

# Secreto para POST /api/tn/events cuando NO viene HMAC de Tiendanube (header x-hache-webhook-secret)
TN_WEBHOOK_SECRET=""

# Secreto de la app OAuth (client secret) — obligatorio si TN envía x-linkedstore-hmac-sha256
# @see https://tiendanube.github.io/api-documentation/resources/webhook
TN_WEBHOOK_APP_SECRET=""

# Tienda Tiendanube (obtenés esto tras instalar la app OAuth)
TN_STORE_USER_ID=""
TN_ACCESS_TOKEN=""
TN_USER_AGENT="HacheSuite (contacto@tudominio.com)"

# URL pública de este backend (la de Railway)
NEXT_PUBLIC_APP_URL="https://tiendaoficial-tiendanube-production.up.railway.app"

# Opcional: tope de IDs de producto por request en GET /api/storefront/dynamic-prices (1–500, default 150)
# STOREFRONT_MAX_PRODUCT_IDS_DYNAMIC_PRICES=150

# Opcional: tiendas brasileñas
# TN_API_HOST=nuvemshop

# Solo para depuración en producción: habilita GET /api/admin/debug-auth y /api/admin/debug-store
# (requieren sesión admin). En desarrollo siempre disponibles.
# ALLOW_ADMIN_DEBUG=1

# PostgreSQL (Railway: se inyecta al conectar el plugin Postgres al servicio)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Firma simple para rutas /api/admin/* (definir un secreto largo)
ADMIN_SECRET="cambiar-por-secreto-largo"

# Tienda (tras instalar app OAuth en la tienda)
TN_STORE_USER_ID=""
TN_ACCESS_TOKEN=""
# Obligatorio: "MiApp (https://...) o email"
TN_USER_AGENT="MiApp (contacto@tudominio.com)"

# Opcional: tiendas BR usan api.nuvemshop.com.br
# TN_API_HOST=nuvemshop

# URL publica del panel (para mostrar el link del webhook en /admin)
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Tienda conectada (user_id = store_id de Tiendanube tras OAuth).
model Store {
  id              String         @id @default(cuid())
  tiendanubeUserId String        @unique
  accessToken     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  paymentRules    PaymentRule[]
  pricePresets    PricePreset[]
  lockedCategories LockedCategory[]
  wishlistItems   WishlistItem[]
  conversionEvents ConversionEvent[]
  adminAuditLogs   AdminAuditLog[]
}

/// Webhooks genéricos recibidos (configurá URL + secreto en TN / integraciones).
model TnWebhookEvent {
  id               String   @id @default(cuid())
  /// Si el JSON trae `store_id` de Tiendanube.
  tiendanubeUserId String?  @db.VarChar(32)
  topic            String   @db.VarChar(160)
  /// Cuerpo crudo (truncado al guardar si excede).
  payload          String   @db.Text
  createdAt        DateTime @default(now())
  processedAt      DateTime?
  processError     String?  @db.VarChar(500)

  @@index([createdAt])
  @@index([tiendanubeUserId, createdAt])
  @@index([processedAt])
}

/// Cambios sensibles en el panel (reglas de pago, precios dinámicos, etc.).
model AdminAuditLog {
  id         String   @id @default(cuid())
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  action     String   @db.VarChar(120)
  entityType String?  @db.VarChar(80)
  entityId   String?  @db.VarChar(80)
  summary    String   @db.VarChar(500)
  meta       String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([storeId, createdAt])
}

/// Eventos de embudo CVR (vista PDP, add to cart, etc.) — ingesta desde hache-suite.js.
model ConversionEvent {
  id         String   @id @default(cuid())
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  /// home_view | category_view | product_view | add_to_cart | bundle_view
  type       String
  productId  Int?
  categoryId Int?
  path       String?  @db.VarChar(512)
  createdAt  DateTime @default(now())

  @@index([storeId, type, createdAt])
}

/// Favoritos por cliente (identificado por ID de cliente TN + email verificado vía API).
model WishlistItem {
  id             String   @id @default(cuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tnCustomerId   Int
  customerEmail  String   @db.VarChar(320)
  productId      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([storeId, tnCustomerId, productId])
  @@index([storeId, productId])
  @@index([storeId, tnCustomerId])
}

/// Reglas evaluadas en el callback payments/before-filter (Business Rules API).
model PaymentRule {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  priority    Int      @default(0)
  /// JSON: { minTotal?, maxTotal?, categoryIdsAny? }
  conditions  String
  /// JSON: [{ "providerId": "...", "optionId": "..." }, ...] a excluir si la condicion cumple
  excludePairs String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId])
}

/// Perfiles de ajuste de precio (subis/bajas % sobre lista actual de la tienda).
model PricePreset {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  percent     Float
  createdAt   DateTime @default(now())

  @@index([storeId])
}

/// Categoria "bloqueada" en tu capa (no es campo nativo de Category en la API).
model LockedCategory {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId  Int
  passwordHash String
  /// TTL en horas para el acceso desbloqueado (default 24h)
  accessTtlHours Int   @default(24)
  createdAt   DateTime @default(now())

  @@unique([storeId, categoryId])
}

/// Regla de regalo en el carrito: si el total supera minTotal, se agrega el producto regalo.
model CartGiftRule {
  id             String   @id @default(cuid())
  storeId        String
  name           String
  minTotal       Float
  /// ID del producto en Tiendanube que se agrega como regalo
  giftProductId  Int
  /// ID de la variante del producto regalo
  giftVariantId  Int
  /// Cantidad a agregar
  giftQty        Int      @default(1)
  /// Título del popup en la tienda (vacío = se usa `name`)
  publicBenefitTitle   String?
  /// Texto del beneficio en el popup (vacío = mensaje genérico con el mínimo)
  publicBenefitMessage String?
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([storeId])
}

/// Configuracion del motor de precios dinamicos por tienda.
/// Solo puede haber una config activa por tienda.
model DynamicPricingConfig {
  id          String   @id @default(cuid())
  storeId     String   @unique
  enabled     Boolean  @default(false)
  /// Nombre del algoritmo: "seeded_random" | "demand_based" | "progressive"
  algorithm   String   @default("seeded_random")
  /// Descuento minimo (porcentaje positivo, ej. 5 = 5%)
  minPct      Float    @default(5)
  /// Descuento maximo (porcentaje positivo, ej. 20 = 20%)
  maxPct      Float    @default(20)
  /// TTL en horas para el cache en localStorage
  cacheTtlHours Int    @default(4)
  /// IDs de categorias excluidas del motor (JSON array de enteros)
  excludedCategoryIds String @default("[]")
  /// Si true, antes de agregar al carrito se hace PATCH del precio en Tiendanube (afecta a todos los compradores).
  commitOnAddToCart Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Bundle (combo) de productos con precio especial.
model Bundle {
  id          String          @id @default(cuid())
  storeId     String
  name        String
  description String?
  /// Precio especial del combo en la moneda de la tienda
  comboPrice  Float
  /// URL de imagen representativa del bundle (puede ser de TN o externa)
  imageUrl    String?
  enabled     Boolean         @default(true)
  products    BundleProduct[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([storeId])
}

/// Producto dentro de un bundle.
model BundleProduct {
  id          String  @id @default(cuid())
  bundleId    String
  bundle      Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  /// ID del producto en Tiendanube
  productId   Int
  /// ID de la variante (0 = primera al resolver; si customerPicksVariant, referencia por defecto en admin)
  variantId   Int     @default(0)
  /// Si true, en la tienda el cliente elige entre todas las variantes del producto (API envía variantChoices).
  customerPicksVariant Boolean @default(false)
  /// Nombre para mostrar (cacheado para no re-fetchear siempre)
  productName String
  /// Miniatura del producto (URL) para listados y PDP
  thumbnailUrl String?
  /// Precio unitario original (informativo)
  unitPrice   Float   @default(0)
  quantity    Int     @default(1)

  @@index([bundleId])
}

# Copiá a .env y completá con FTP del admin: Tienda online > Diseño > Editar código > Abrir FTP.
# https://ayuda.tiendanube.com/es_ES/123227-editar-el-codigo-de-diseno/como-modificar-el-diseno-desde-el-codigo-de-mi-tienda

FTP_HOST=ftp.tiendanube.com
FTP_USER=tu_usuario_ftp
FTP_PASSWORD=tu_password_ftp
FTP_PORT=21
# Tiendanube suele exigir TLS; si ves error 534, usá true:
FTP_SECURE=true
FTP_BASE_PATH=/
FTP_TIMEOUT=30000
DEBUG=false
